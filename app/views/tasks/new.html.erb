<h1>Create a New Task</h1>

<%= form_with model: @task do |form| %>

  <div style="margin-bottom: 20px;">
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

<div style="margin-bottom: 20px;">
    <%= form.label :details %>
    <%= form.text_area :details %>
  </div>

  <div>
    <%= form.submit %>
  </div>

<% end %>
